<Example ID="EWJD4R6B">

<Listing>
<L>/* Дерево */</L>
<L>struct node {int         key;</L>
<L>             char        description [50];</L>
<L>             struct node *left, *right;</L>
<L>            };</L>
</Listing>
</Example>
